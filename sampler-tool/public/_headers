# Cloudflare Pages headers
# Files in public/ are copied to dist/ root by Vite, so this lands at dist/_headers
# and Cloudflare Pages applies it.

# ── Security headers (apply to everything) ─────────────────────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(self), geolocation=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self'; worker-src 'self' blob:; manifest-src 'self'; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# ── Service Worker — must never be stale ───────────────────────────────
# Browsers re-check SW on every navigation, but a stale CDN cache could
# serve an old sw.js for hours. no-cache forces revalidation each request.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# Workbox runtime — same logic as sw.js
/workbox-*.js
  Cache-Control: public, max-age=0, must-revalidate

# ── Manifest — short cache so install metadata can update ──────────────
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# ── Hashed assets — Vite hashes filenames so safe to cache forever ─────
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ── HTML — must revalidate so SW update flow works ─────────────────────
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Icons / static images — daily cache ─────────────────────────────────
/*.png
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400
